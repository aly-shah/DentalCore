# Copy this file to android/keystore.properties (gitignored) and fill in the
# values to sign release APK builds. Leave this example file in git so future
# contributors know what to set.
#
# Alternatively, set these as environment variables when running gradle:
#   DENTACORE_KEYSTORE_FILE
#   DENTACORE_KEYSTORE_PASSWORD
#   DENTACORE_KEY_ALIAS
#   DENTACORE_KEY_PASSWORD
#
# storeFile path is relative to the android/app/ directory.

storeFile=../dentacore-release.keystore
storePassword=CHANGE_ME
keyAlias=dentacore
keyPassword=CHANGE_ME
