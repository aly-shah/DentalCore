// =====================================================================
// Dental treatment planning (bible §4.13)
// =====================================================================

/// A phased dental treatment plan. Tracks proposed → accepted →
/// in-progress → completed. Each plan can be flat (items only) or
/// phased (items grouped under phases for multi-visit work).
model TreatmentPlan {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId  String?

  proposedById String // doctor user id
  acceptedById String? // who at the clinic recorded acceptance

  status String @default("DRAFT")
  // DRAFT / PROPOSED / ACCEPTED / IN_PROGRESS / COMPLETED / CANCELLED

  title     String?
  diagnosis String?
  rationale String?

  priority String @default("MEDIUM")
  // EMERGENCY / HIGH / MEDIUM / COSMETIC

  proposedAt  DateTime?
  presentedAt DateTime?
  acceptedAt  DateTime?
  completedAt DateTime?

  patientSignatureUrl String?
  consentRequired     Boolean @default(false)
  consentSigned       Boolean @default(false)

  totalCost                  Float @default(0)
  estimatedInsuranceCoverage Float @default(0)
  estimatedPatientPortion    Float @default(0)

  notes     String?
  invoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases TreatmentPlanPhase[]
  items  TreatmentPlanItem[]

  @@index([patientId, status])
  @@index([tenantId])
}

model TreatmentPlanPhase {
  id             String        @id @default(cuid())
  planId         String
  plan           TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  order          Int
  title          String
  description    String?
  estimatedWeeks Int?
  status         String        @default("PENDING") // PENDING / IN_PROGRESS / COMPLETED / SKIPPED

  items TreatmentPlanItem[]

  @@index([planId])
}

model TreatmentPlanItem {
  id      String              @id @default(cuid())
  planId  String?
  plan    TreatmentPlan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  phaseId String?
  phase   TreatmentPlanPhase? @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  treatmentId String? // loose FK to Treatment catalog
  cdtCode     String?

  fdi               Int?
  surface           String? // MESIAL / DISTAL / OCCLUSAL / BUCCAL / LINGUAL
  description       String
  quantity          Int     @default(1)
  unitPrice         Float
  total             Float
  insuranceCoverage Float   @default(0)
  patientPortion    Float   @default(0)

  procedureId String? // populated when performed
  performedAt DateTime?

  status String @default("PROPOSED")
  // PROPOSED / ACCEPTED / IN_PROGRESS / COMPLETED / DECLINED

  notes String?

  @@index([planId])
  @@index([phaseId])
}

// =====================================================================
// Dental procedure templates (bible §3.5)
// =====================================================================
/// Pre-built procedure templates for common dental procedures.
/// Pre-fill consultation + procedure flows with diagnosis, notes,
/// post-op instructions, default Rx items, and follow-up cadence.

model TreatmentTemplate {
  id       String  @id @default(cuid())
  tenantId String?

  code     String  @unique // SCALE_POLISH / RCT_MOLAR / etc.
  name     String
  category String // Preventive / Restorative / Endodontic / etc.
  cdtCode  String?

  defaultDiagnosis          String?
  defaultChiefComplaint     String?
  defaultClinicalFindings   String?
  defaultProcedureNotes     String?
  defaultMaterialsUsed      String?
  defaultPostOpInstructions String?
  defaultFollowUpDays       Int?

  /// Array of { medicineName, dosage, frequency, duration, instructions? }
  defaultRxItems Json?

  defaultPrice    Float @default(0)
  defaultDuration Int   @default(30)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([category])
}

// =====================================================================
// AI governance (enterprise bible §5)
// =====================================================================

/// Versioned AI model invocation parameters. One row per
/// (subsystem, modelId, promptVersion) tuple. Active row is used by the
/// service; historical rows are retained for audit/rollback.
model AIModelVersion {
  id            String    @id @default(cuid())
  name          String // e.g. "treatment-suggestion", "voice-transcription"
  provider      String // "openai" / "anthropic" / "in-house"
  modelId       String // "gpt-4o-mini" / "whisper-1" / etc.
  promptVersion String // "v1" / "v2.1"
  systemPrompt  String? // verbatim system prompt
  temperature   Float?
  maxTokens     Int?
  isActive      Boolean   @default(true)
  deprecatedAt  DateTime?
  createdAt     DateTime  @default(now())

  suggestions AISuggestionLog[]

  @@unique([name, modelId, promptVersion])
  @@index([name, isActive])
}

/// Provenance for every AI call. Stores model version, raw inputs/outputs,
/// confidence, cost, and the downstream acceptance status. Medically
/// defensible — every clinical artifact derived from AI is traceable.
model AISuggestionLog {
  id             String         @id @default(cuid())
  tenantId       String?
  patientId      String?
  doctorId       String?
  appointmentId  String?
  modelVersionId String
  modelVersion   AIModelVersion @relation(fields: [modelVersionId], references: [id])

  subsystem        String // mirror of AIModelVersion.name
  inputSnapshot    Json // exact inputs (may be PHI-truncated)
  inputHash        String // SHA-256 of the canonical input
  rawResponse      Json? // verbatim provider response
  parsedResponse   Json? // structured form
  confidence       Float?
  latencyMs        Int?
  costCents        Float?
  promptTokens     Int?
  completionTokens Int?

  status String @default("PROPOSED")
  // PROPOSED / ACCEPTED / REJECTED / EXPIRED / ERRORED

  acceptedEntityType String?
  acceptedEntityId   String?
  acceptedById       String?
  acceptedAt         DateTime?
  rejectionReason    String?
  errorMessage       String?

  createdAt DateTime @default(now())

  feedback AISuggestionFeedback[]

  @@index([tenantId, subsystem, createdAt])
  @@index([patientId])
  @@index([status])
}

/// Clinician feedback on an AI suggestion. Drives model quality metrics
/// (flag-as-inaccurate rate per subsystem per model version).
model AISuggestionFeedback {
  id               String          @id @default(cuid())
  suggestionLogId  String
  suggestion       AISuggestionLog @relation(fields: [suggestionLogId], references: [id], onDelete: Cascade)
  reviewedById     String?
  rating           Int // 1-5
  feedback         String?
  flagAsInaccurate Boolean         @default(false)
  flagAsHarmful    Boolean         @default(false)
  createdAt        DateTime        @default(now())

  @@index([suggestionLogId])
}
