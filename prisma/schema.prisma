// DentaCore ERP — Prisma Schema (PostgreSQL)
// Local dev can still use SQLite by changing `provider` below and the
// DATABASE_URL env to `file:./dev.db`; CI deploys to PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// MULTI-TENANT SAAS — Phase A
// =====================================================================
// Tenant is the root of multi-tenancy. Today the app runs as a single
// implicit tenant (created by the backfill script). Phase A adds the
// model + nullable tenantId on top-level entities. Phase B will populate
// it everywhere and start enforcing via Prisma middleware. Phase C makes
// columns NOT NULL.

model Tenant {
  id        String  @id @default(cuid())
  slug      String  @unique // URL-safe, immutable
  name      String
  legalName String?

  plan   String @default("FREE") // FREE / PRO / GROUP / ENTERPRISE
  status String @default("ACTIVE") // ACTIVE / TRIAL / SUSPENDED / CHURNED / ARCHIVED

  // Branding
  logoUrl        String?
  wordmarkUrl    String?
  faviconUrl     String?
  primaryColor   String  @default("#0284C7")
  secondaryColor String?

  // Localization
  locale     String @default("en")
  currency   String @default("USD")
  timezone   String @default("UTC")
  dateFormat String @default("MM/DD/YYYY")

  // Compliance
  region       String  @default("global") // US / EU / APAC / global
  hipaaCovered Boolean @default(false)
  gdprCovered  Boolean @default(false)

  // Plan limits (cached overrides)
  maxUsers             Int?
  maxBranches          Int?
  maxPatients          Int?
  monthlyAiBudgetCents Int?
  storageQuotaGB       Float?

  // Subscription
  trialEndsAt     DateTime?
  suspendedAt     DateTime?
  suspendedReason String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostnames  TenantHostname[]
  users      User[]
  branches   Branch[]
  patients   Patient[]
  treatments Treatment[]
  packages   Package[]
  leads      Lead[]
  rooms      Room[]
  products   Product[]
  settings   Setting[]

  @@index([status])
  @@index([plan])
}

model TenantHostname {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  hostname          String  @unique // dental.scalamedic.com OR smiles.dentacore.app
  type              String // CUSTOM / SUBDOMAIN / DEFAULT
  isVerified        Boolean @default(false)
  verificationToken String?
  tlsManagedBy      String  @default("PLATFORM") // PLATFORM / CUSTOMER
  isPrimary         Boolean @default(false)

  createdAt  DateTime  @default(now())
  verifiedAt DateTime?

  @@index([tenantId])
}

// =====================================================================
// Existing models
// =====================================================================

model Branch {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  name      String
  code      String?
  address   String?
  phone     String?
  email     String?
  timezone  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  patients Patient[]
  appts    Appointment[]
  rooms    Room[]
  leads    Lead[]
  invoices Invoice[]
  products Product[]

  @@index([tenantId])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  email         String    @unique
  name          String
  phone         String?
  avatar        String?
  role          String    @default("RECEPTIONIST")
  passwordHash  String
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  speciality    String?
  licenseNumber String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAppointments Appointment[]      @relation("CreatedBy")
  doctorAppointments  Appointment[]      @relation("Doctor")
  createdInvoices     Invoice[]          @relation("InvoiceCreatedBy")
  paymentsProcessed   Payment[]          @relation("PaymentProcessedBy")
  notes               ConsultationNote[]
  prescriptions       Prescription[]
  procedures          Procedure[]
  labTests            LabTest[]
  leadsAssigned       Lead[]
  callLogs            CallLog[]
  followUps           FollowUp[]
  aiTranscriptions    AITranscription[]
  notifications       Notification[]
  triages             Triage[]
  auditLogs           AuditLog[]
  patientsAssigned    Patient[]
  schedules           Schedule[]
  leaves              DoctorLeave[]
  orthoCases          OrthoCase[]        @relation("OrthoCaseDoctor")

  @@index([tenantId])
}

model Patient {
  id                 String    @id @default(cuid())
  tenantId           String?
  tenant             Tenant?   @relation(fields: [tenantId], references: [id])
  patientCode        String    @unique
  firstName          String
  middleName         String?
  lastName           String
  email              String?
  phone              String?
  dateOfBirth        DateTime?
  gender             String    @default("OTHER")
  nationality        String?
  address            String?
  city               String?
  emergencyContact   String?
  emergencyPhone     String?
  bloodType          String?
  profileImage       String?
  notes              String?
  source             String?
  consentGiven       Boolean   @default(false)
  isVip              Boolean   @default(false)
  deletedAt          DateTime?
  isActive           Boolean   @default(true)
  skinType           String?
  lastVisit          DateTime?
  nextAppointment    DateTime?
  outstandingBalance Float     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  assignedDoctorId String?
  assignedDoctor   User?   @relation(fields: [assignedDoctorId], references: [id])

  allergies         Allergy[]
  tags              PatientTag[]
  appointments      Appointment[]
  notes_records     ConsultationNote[]
  procedures        Procedure[]
  prescriptions     Prescription[]
  labTests          LabTest[]
  documents         PatientDocument[]
  invoices          Invoice[]
  packages          PatientPackage[]
  followUps         FollowUp[]
  skinHistory       SkinHistory[]
  medicalHistory    MedicalHistory[]
  comms             CommunicationLog[]
  aiTranscripts     AITranscription[]
  triages           Triage[]
  consents          Consent[]
  convertedLeads    Lead[]             @relation("LeadConvertedPatient")
  callLogs          CallLog[]          @relation("PatientCallLogs")
  toothRecords      ToothRecord[]
  orthoCases        OrthoCase[]
  beforeAfterImages BeforeAfterImage[]
  DentalChart       DentalChart[]
  TreatmentPlan     TreatmentPlan[]

  @@index([tenantId])
}

model BeforeAfterImage {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  beforeUrl String
  afterUrl  String?

  title       String?
  description String?
  toothFdi    Int?
  procedure   String?

  takenAt        DateTime @default(now())
  uploadedById   String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([takenAt])
}

model OrthoCase {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String?
  doctor    User?   @relation("OrthoCaseDoctor", fields: [doctorId], references: [id])

  type   String @default("METAL") // METAL, CERAMIC, LINGUAL, CLEAR_ALIGNER, SELF_LIGATING
  arches String @default("BOTH") // UPPER, LOWER, BOTH
  status String @default("CONSULTATION") // CONSULTATION, RECORDS, PLANNING, ACTIVE, RETENTION, COMPLETED, CANCELLED

  chiefComplaint String?
  diagnosis      String?
  treatmentPlan  String?

  startDate        DateTime?
  estimatedEndDate DateTime?
  actualEndDate    DateTime?
  intervalWeeks    Int       @default(4)

  totalCost  Float @default(0)
  paidAmount Float @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visits OrthoVisit[]

  @@index([patientId])
  @@index([status])
}

model OrthoVisit {
  id        String    @id @default(cuid())
  caseId    String
  orthoCase OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type      String   @default("ADJUSTMENT") // BRACKET_PLACEMENT, ADJUSTMENT, WIRE_CHANGE, ELASTICS, REMOVAL, RETAINER_FITTING, PROGRESS_CHECK, EMERGENCY
  visitDate DateTime @default(now())

  performedById   String?
  performedByName String?

  wireUpper String?
  wireLower String?
  elastics  String?

  notes         String?
  complications String?
  nextVisitDate DateTime?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([visitDate])
}

model ToothRecord {
  id        String       @id @default(cuid())
  patientId String
  patient   Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  chartId   String?
  chart     DentalChart? @relation(fields: [chartId], references: [id], onDelete: SetNull)

  fdi    Int // 11-48 permanent; 51-85 primary (mixed dentition)
  status String @default("HEALTHY")
  // HEALTHY / CARIES / FILLING / CROWN / BRIDGE / IMPLANT / MISSING /
  // ROOT_CANAL / EXTRACTION_NEEDED / MOBILITY / FRACTURE / PROBLEM /
  // UNDER_TREATMENT / TREATED

  conditions String? // legacy: comma-separated condition tags
  treatment  String? // legacy: single applied-treatment text

  plannedTreatment   String?
  completedTreatment String?

  // Surface-level data: { mesial?: {...}, distal?, occlusal?, buccal?, lingual? }
  // Each surface holds { condition?, treatment?, plannedTreatment?, completedTreatment?, notes? }
  surfaces Json?

  priority String  @default("MEDIUM") // EMERGENCY / HIGH / MEDIUM / COSMETIC
  notes    String?

  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events ToothEvent[]

  @@unique([patientId, fdi])
  @@index([patientId])
  @@index([chartId])
}

/// Versioned dental chart. A patient typically has one active chart with
/// the current state; new charts are created when the dentist wants a
/// "fresh exam" snapshot (e.g., at recall or new-patient exam).
model DentalChart {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenantId  String?

  numberingSystem String @default("FDI") // FDI / UNIVERSAL
  dentition       String @default("ADULT") // ADULT / MIXED / PEDIATRIC

  isPrimary   Boolean @default(true)
  createdById String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teeth ToothRecord[]

  @@index([patientId])
  @@index([tenantId])
}

/// Audit / history trail for tooth state changes. Lets us answer
/// "show me everything that happened on tooth 16 for this patient".
model ToothEvent {
  id            String      @id @default(cuid())
  toothRecordId String
  tooth         ToothRecord @relation(fields: [toothRecordId], references: [id], onDelete: Cascade)

  occurredAt DateTime @default(now())
  eventType  String
  // STATUS_CHANGED / DIAGNOSIS_ADDED / TREATMENT_PLANNED /
  // TREATMENT_COMPLETED / IMAGING_TAKEN / PROCEDURE_PERFORMED / NOTE_ADDED

  previousStatus String?
  newStatus      String?
  surface        String? // MESIAL / DISTAL / OCCLUSAL / BUCCAL / LINGUAL
  notes          String?
  procedureId    String?
  performedById  String?

  createdAt DateTime @default(now())

  @@index([toothRecordId, occurredAt])
}

model Allergy {
  id        String  @id @default(cuid())
  patientId String
  allergen  String
  severity  String?
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientTag {
  id        String  @id @default(cuid())
  patientId String
  tag       String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Appointment {
  id               String    @id @default(cuid())
  appointmentCode  String    @unique
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id])
  doctorId         String
  doctor           User      @relation("Doctor", fields: [doctorId], references: [id])
  branchId         String
  branch           Branch    @relation(fields: [branchId], references: [id])
  roomId           String?
  room             Room?     @relation(fields: [roomId], references: [id])
  date             DateTime
  startTime        String
  endTime          String
  durationMinutes  Int?
  type             String    @default("CONSULTATION")
  status           String    @default("SCHEDULED")
  notes            String?
  priority         String    @default("NORMAL")
  waitlistPosition Int?
  checkinTime      DateTime?
  checkoutTime     DateTime?
  workflowStage    String    @default("BOOKED")
  cancellationNote String?
  createdById      String
  createdBy        User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  consultationNote ConsultationNote?
  procedures       Procedure[]
  invoice          Invoice?
  prescriptions    Prescription[]
  labTests         LabTest[]
  aiTranscription  AITranscription?
  followUps        FollowUp[]
  triage           Triage?
}

model ConsultationNote {
  id                String      @id @default(cuid())
  appointmentId     String      @unique
  appointment       Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId         String
  patient           Patient     @relation(fields: [patientId], references: [id])
  doctorId          String
  doctor            User        @relation(fields: [doctorId], references: [id])
  chiefComplaint    String?
  symptoms          String?
  examination       String?
  skinAssessment    String?
  affectedAreas     String?
  conditionSeverity String?
  diagnosis         String?
  differentialDx    String?
  treatmentPlan     String?
  advice            String?
  internalNotes     String?
  followUpDate      DateTime?
  followUpNotes     String?
  isSigned          Boolean     @default(false)
  signedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Treatment {
  id                String   @id @default(cuid())
  tenantId          String?
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  name              String
  code              String?
  category          String   @default("OTHER")
  description       String?
  duration          Int      @default(30)
  basePrice         Float    @default(0)
  preInstructions   String?
  postInstructions  String?
  contraindications String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  procedures        Procedure[]
  packageTreatments PackageTreatment[]

  @@index([tenantId])
}

model Procedure {
  id            String       @id @default(cuid())
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User         @relation(fields: [doctorId], references: [id])
  treatmentId   String
  treatment     Treatment    @relation(fields: [treatmentId], references: [id])
  notes         String?
  outcome       String?
  complications String?
  beforeImages  String?
  afterImages   String?
  areasTreated  String?
  consentSigned Boolean      @default(false)
  settings      String?
  performedAt   DateTime     @default(now())
  createdAt     DateTime     @default(now())
}

model Prescription {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User         @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  notes         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineName   String
  dosage         String?
  frequency      String?
  duration       String?
  route          String?
  instructions   String?
}

model LabTest {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User         @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  testName      String
  testCode      String?
  priority      String?
  status        String       @default("REQUESTED")
  results       String?
  technician    String?
  collectedAt   DateTime?
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
}

model PatientDocument {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id])
  name           String
  type           String   @default("OTHER")
  mimeType       String?
  fileUrl        String
  fileSize       Int      @default(0)
  uploadedById   String
  uploadedByName String?
  notes          String?
  createdAt      DateTime @default(now())
}

model Invoice {
  id            String       @id @default(cuid())
  invoiceNumber String       @unique
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  branchId      String
  branch        Branch       @relation(fields: [branchId], references: [id])
  subtotal      Float        @default(0)
  discount      Float        @default(0)
  discountType  String       @default("FIXED")
  tax           Float        @default(0)
  total         Float        @default(0)
  amountPaid    Float        @default(0)
  balanceDue    Float        @default(0)
  status        String       @default("DRAFT")
  dueDate       DateTime?
  notes         String?
  createdById   String
  createdBy     User         @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items    InvoiceItem[]
  payments Payment[]
  refunds  Refund[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  type        String  @default("PROCEDURE")
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0)
}

model Payment {
  id              String   @id @default(cuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount          Float
  method          String   @default("CASH")
  reference       String?
  notes           String?
  status          String   @default("COMPLETED")
  processedById   String
  processedBy     User?    @relation("PaymentProcessedBy", fields: [processedById], references: [id])
  processedByName String?
  processedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
}

model Refund {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  amount        Float
  method        String?
  reference     String?
  reason        String?
  notes         String?
  status        String   @default("COMPLETED")
  processedById String?
  approvedById  String?
  createdAt     DateTime @default(now())
}

model Package {
  id              String   @id @default(cuid())
  tenantId        String?
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  name            String
  description     String?
  price           Float    @default(0)
  validityDays    Int      @default(365)
  maxRedemptions  Int?
  isActive        Boolean  @default(true)
  subscriberCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  treatments      PackageTreatment[]
  patientPackages PatientPackage[]

  @@index([tenantId])
}

model PackageTreatment {
  id            String    @id @default(cuid())
  packageId     String
  package       Package   @relation(fields: [packageId], references: [id], onDelete: Cascade)
  treatmentId   String
  treatment     Treatment @relation(fields: [treatmentId], references: [id])
  treatmentName String
  sessions      Int       @default(1)
}

model PatientPackage {
  id                String    @id @default(cuid())
  patientId         String
  patient           Patient   @relation(fields: [patientId], references: [id])
  packageId         String
  package           Package   @relation(fields: [packageId], references: [id])
  packageName       String
  purchaseDate      DateTime  @default(now())
  expiryDate        DateTime?
  remainingSessions String?
  status            String    @default("ACTIVE")
  invoiceId         String?
}

model Lead {
  id                 String    @id @default(cuid())
  tenantId           String?
  tenant             Tenant?   @relation(fields: [tenantId], references: [id])
  name               String
  phone              String
  email              String?
  source             String    @default("CALL")
  status             String    @default("NEW")
  interest           String?
  assignedToId       String?
  assignedTo         User?     @relation(fields: [assignedToId], references: [id])
  branchId           String
  branch             Branch    @relation(fields: [branchId], references: [id])
  notes              String?
  convertedPatientId String?
  convertedPatient   Patient?  @relation("LeadConvertedPatient", fields: [convertedPatientId], references: [id])
  callbackDate       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  callLogs CallLog[]

  @@index([tenantId])
}

model CallLog {
  id         String   @id @default(cuid())
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  patientId  String?
  patient    Patient? @relation("PatientCallLogs", fields: [patientId], references: [id])
  callerName String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  agentName  String?
  type       String   @default("INBOUND")
  duration   Int      @default(0)
  notes      String?
  outcome    String?
  createdAt  DateTime @default(now())
}

model CommunicationLog {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  type       String   @default("SMS")
  direction  String   @default("OUTBOUND")
  subject    String?
  content    String
  sentById   String?
  sentByName String?
  createdAt  DateTime @default(now())
}

model FollowUp {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User         @relation(fields: [doctorId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  dueDate       DateTime
  reason        String
  status        String       @default("PENDING")
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AITranscription {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id])
  patientId      String
  patient        Patient     @relation(fields: [patientId], references: [id])
  doctorId       String
  doctor         User        @relation(fields: [doctorId], references: [id])
  rawTranscript  String?
  structuredNote String?
  summary        String?
  language       String?     @default("en")
  status         String      @default("COMPLETED")
  duration       Int         @default(0)
  createdAt      DateTime    @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model Triage {
  id               String       @id @default(cuid())
  patientId        String
  patient          Patient      @relation(fields: [patientId], references: [id])
  appointmentId    String?      @unique
  appointment      Appointment? @relation(fields: [appointmentId], references: [id])
  temperature      Float?
  temperatureUnit  String?      @default("C")
  systolicBP       Int?
  diastolicBP      Int?
  heartRate        Int?
  respiratoryRate  Int?
  weight           Float?
  height           Float?
  oxygenSaturation Int?
  painLevel        Int?
  moistureLevel    String?
  oilinessLevel    String?
  bmi              String?
  notes            String?
  skinObservations String?
  urgencyLevel     String       @default("ROUTINE")
  recordedById     String
  recordedBy       User         @relation(fields: [recordedById], references: [id])
  createdAt        DateTime     @default(now())
}

model Room {
  id                 String    @id @default(cuid())
  tenantId           String?
  tenant             Tenant?   @relation(fields: [tenantId], references: [id])
  branchId           String
  branch             Branch    @relation(fields: [branchId], references: [id])
  name               String
  number             String?
  type               String    @default("CONSULTATION")
  status             String    @default("AVAILABLE")
  isAvailable        Boolean   @default(true)
  capacity           Int       @default(1)
  floor              String?
  equipment          String?
  currentPatientId   String?
  currentPatientName String?
  currentDoctorName  String?
  occupiedSince      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  appointments Appointment[]

  @@index([tenantId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userName   String?
  action     String
  module     String?
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model SkinHistory {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id])
  condition        String
  affectedArea     String?
  severity         String    @default("MILD")
  onsetDate        DateTime?
  treatmentHistory String?
  notes            String?
  images           String?
  createdAt        DateTime  @default(now())
}

model MedicalHistory {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  condition     String
  diagnosedDate DateTime?
  status        String    @default("ACTIVE")
  notes         String?
  createdAt     DateTime  @default(now())
}

model Product {
  id           String    @id @default(cuid())
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  name         String
  description  String?
  sku          String?
  barcode      String?
  brand        String?
  category     String    @default("OTHER")
  unit         String?
  sellPrice    Float     @default(0)
  costPrice    Float     @default(0)
  quantity     Int       @default(0)
  reorderLevel Int       @default(5)
  expiryDate   DateTime?
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
}

model Schedule {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      User     @relation(fields: [doctorId], references: [id])
  dayOfWeek   Int
  startTime   String
  endTime     String
  breakStart  String?
  breakEnd    String?
  slotMinutes Int      @default(30)
  isActive    Boolean  @default(true)
